<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feiting.feiapi.mapper.InterfaceQuotaConfigMapper">

    <resultMap id="BaseResultMap" type="com.feiting.feiapicommon.model.entity.InterfaceQuotaConfig">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="quotaType" column="quota_type" jdbcType="VARCHAR"/>
        <result property="initialQuota" column="initial_quota" jdbcType="INTEGER"/>
        <result property="description" column="description" jdbcType="VARCHAR"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="isDelete" column="is_delete" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,quota_type,initial_quota,description,
        create_time,update_time,is_delete
    </sql>

    <insert id="insertDefaultConfigIgnore">
        insert into interface_quota_config (quota_type, initial_quota, description, is_delete)
        values (#{quotaType}, #{initialQuota}, #{description}, 0)
        on duplicate key update
            quota_type = quota_type
    </insert>
</mapper>
