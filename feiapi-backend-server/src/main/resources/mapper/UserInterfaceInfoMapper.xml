<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feiting.feiapi.mapper.UserInterfaceInfoMapper">

    <resultMap id="BaseResultMap" type="com.feiting.feiapicommon.model.entity.UserInterfaceInfo">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="interfaceInfoId" column="interface_info_id" jdbcType="BIGINT"/>
            <result property="totalNum" column="total_num" jdbcType="INTEGER"/>
            <result property="leftNum" column="left_num" jdbcType="INTEGER"/>
            <result property="status" column="status" jdbcType="INTEGER"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="isDelete" column="is_delete" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,user_id,interface_info_id,
        total_num,left_num,status,
        create_time,update_time,is_delete
    </sql>

    <!--List<UserInterfaceInfo> listTopInvokeInterfaceInfo(int limit);-->
    <select id="listTopInvokeInterfaceInfo" resultType="com.feiting.feiapicommon.model.entity.UserInterfaceInfo">
        select interface_info_id, sum(total_num) as total_num
        from user_interface_info
        where is_delete = 0
        group by interface_info_id
        order by total_num desc limit #{limit};
    </select>

    <insert id="insertIgnoreIfAbsent">
        insert into user_interface_info (user_id, interface_info_id, left_num, total_num, is_delete)
        values (#{userId}, #{interfaceInfoId}, #{leftNum}, #{totalNum}, 0)
        on duplicate key update
            is_delete = 0,
            left_num = values(left_num),
            total_num = values(total_num)
    </insert>
</mapper>
