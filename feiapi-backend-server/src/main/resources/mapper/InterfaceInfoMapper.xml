<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.feiting.feiapi.mapper.InterfaceInfoMapper">

    <resultMap id="BaseResultMap" type="com.feiting.feiapicommon.model.entity.InterfaceInfo">
            <id property="id" column="id" jdbcType="BIGINT"/>
            <result property="name" column="name" jdbcType="VARCHAR"/>
            <result property="sdkMethodName" column="sdk_method_name" jdbcType="VARCHAR"/>
            <result property="description" column="description" jdbcType="VARCHAR"/>
            <result property="url" column="url" jdbcType="VARCHAR"/>
            <result property="path" column="path" jdbcType="VARCHAR"/>
            <result property="targetHost" column="target_host" jdbcType="VARCHAR"/>
            <result property="requestParams" column="request_params" jdbcType="VARCHAR"/>
            <result property="requestHeader" column="request_header" jdbcType="VARCHAR"/>
            <result property="responseHeader" column="response_header" jdbcType="VARCHAR"/>
            <result property="status" column="status" jdbcType="INTEGER"/>
            <result property="method" column="method" jdbcType="VARCHAR"/>
            <result property="quotaType" column="quota_type" jdbcType="VARCHAR"/>
            <result property="userId" column="user_id" jdbcType="BIGINT"/>
            <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
            <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
            <result property="isDelete" column="is_delete" jdbcType="TINYINT"/>
    </resultMap>

    <sql id="Base_Column_List">
        id,name,sdk_method_name,description,
        url,path,target_host,
        request_params,request_header,response_header,
        status,method,quota_type,
        user_id,create_time,update_time,
        is_delete
    </sql>

    <!-- 按接口调用总数分页查询接口视图 -->
    <select id="selectPageOrderByTotalNum" resultType="com.feiting.feiapi.model.vo.InterfaceInfoVO">
        select
            ii.id,
            ii.name,
            ii.sdk_method_name,
            ii.description,
            ii.url,
            ii.path,
            ii.target_host,
            ii.request_params,
            ii.request_header,
            ii.response_header,
            ii.status,
            ii.method,
            ii.quota_type,
            ii.user_id,
            ii.create_time,
            ii.update_time,
            coalesce(invoke_summary.total_num, 0) as total_num
        from interface_info ii
        left join (
            select interface_info_id, coalesce(sum(total_num), 0) as total_num
            from user_interface_info
            where is_delete = 0
            group by interface_info_id
        ) invoke_summary on invoke_summary.interface_info_id = ii.id
        where ii.is_delete = 0
        <if test="queryRequest.id != null">
            and ii.id = #{queryRequest.id}
        </if>
        <if test="queryRequest.name != null and queryRequest.name != ''">
            and ii.name = #{queryRequest.name}
        </if>
        <if test="queryRequest.sdkMethodName != null and queryRequest.sdkMethodName != ''">
            and ii.sdk_method_name = #{queryRequest.sdkMethodName}
        </if>
        <if test="queryRequest.description != null and queryRequest.description != ''">
            and ii.description like concat('%', #{queryRequest.description}, '%')
        </if>
        <if test="queryRequest.url != null and queryRequest.url != ''">
            and ii.url = #{queryRequest.url}
        </if>
        <if test="queryRequest.path != null and queryRequest.path != ''">
            and ii.path = #{queryRequest.path}
        </if>
        <if test="queryRequest.targetHost != null and queryRequest.targetHost != ''">
            and ii.target_host = #{queryRequest.targetHost}
        </if>
        <if test="queryRequest.requestParams != null and queryRequest.requestParams != ''">
            and ii.request_params = #{queryRequest.requestParams}
        </if>
        <if test="queryRequest.requestHeader != null and queryRequest.requestHeader != ''">
            and ii.request_header = #{queryRequest.requestHeader}
        </if>
        <if test="queryRequest.responseHeader != null and queryRequest.responseHeader != ''">
            and ii.response_header = #{queryRequest.responseHeader}
        </if>
        <if test="status != null">
            and ii.status = #{status}
        </if>
        <if test="method != null and method != ''">
            and ii.method = #{method}
        </if>
        <if test="queryRequest.quotaType != null and queryRequest.quotaType != ''">
            and ii.quota_type = #{queryRequest.quotaType}
        </if>
        <if test="queryRequest.userId != null">
            and ii.user_id = #{queryRequest.userId}
        </if>
        order by coalesce(invoke_summary.total_num, 0)
        <choose>
            <when test="asc">
                asc
            </when>
            <otherwise>
                desc
            </otherwise>
        </choose>
        , ii.id asc
    </select>
</mapper>
